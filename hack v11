local function switchTab(tabName)
    PageFarm.Visible = (tabName == "Farm")
    PageMonster.Visible = (tabName == "Monster")
    PageIsland.Visible = (tabName == "Island")
    PageNPC.Visible = (tabName == "NPC")
    
    local tabs = {
        {BtnTabFarm, "Farm", Color3.fromRGB(58, 117, 196)},
        {BtnTabMonster, "Monster", Color3.fromRGB(58, 117, 196)},
        {BtnTabIsland, "Island", Color3.fromRGB(58, 117, 196)},
        {BtnTabNPC, "NPC", Color3.fromRGB(46, 204, 113)}
    }
    
    for _, t in ipairs(tabs) do
        local active = (tabName == t[2])
        TweenService:Create(t[1], TweenInfo.new(0.18), {
            BackgroundColor3 = active and t[3] or Color3.fromRGB(30, 35, 48), 
            TextColor3 = active and Color3.fromRGB(255,255,255) or Color3.fromRGB(150, 160, 185)
        }):Play()
    end
end

