        for f = 1, #fruitList do
            if not _G.autoFruitRemote then break end
            local fruitName = fruitList[f]
            local targetFruit = workspace:FindFirstChild(fruitName)
            if targetFruit then
                local cd = targetFruit:FindFirstChildWhichIsA("ClickDetector", true)
                if cd then pcall(fireclickdetector, cd) end
                
                local children = targetFruit:GetChildren()
                for c = 1, #children do
                    local subCd = children[c]:FindFirstChildWhichIsA("ClickDetector", true)
                    if subCd then pcall(fireclickdetector, subCd) end
                end
            end
        end
        task_wait(FRUIT_INTERVAL)
    end
end

