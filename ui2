    end)

    bossFarmConnection = RunService.Heartbeat:Connect(function()
        if not _G.autoBossFarm then return end
        local hrp = getHRP() if not hrp or player.Character.Humanoid.Health <= 0 then return end
        local aliveFolder = workspace:FindFirstChild("Alive") if not aliveFolder then return end

        if currentBossTarget and currentBossTarget.Parent and currentBossTarget:FindFirstChild("HumanoidRootPart") and currentBossTarget.Humanoid.Health > 0 then
