local activePages = {}
local tabButtons = {}

local function createPage(pageName)
    local page = Instance.new("ScrollingFrame")
    page.Name = "Page_" .. pageName
    page.Parent = ViewportContent
    page.BackgroundTransparency = 1
    page.Size = UDim2.new(1, 0, 1, 0)
    page.ScrollBarThickness = 2
    page.ScrollBarImageColor3 = Theme.Border
    page.Visible = false
    
    local list = Instance.new("UIListLayout")
    list.Parent = page
    list.SortOrder = Enum.SortOrder.LayoutOrder
    list.Padding = UDim.new(0, 8)
    
    list:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        page.CanvasSize = UDim2.new(0, 0, 0, list.AbsoluteContentSize.Y + 12)
    end)
    
    activePages[pageName] = page
    return page
end

local function handleAFKMenuProtection(isAutoActive)
    if isAutoActive then
        -- Khi cắm auto, thu hẹp tương tác menu tránh click ảo đè lên
        MainFrame.ClipsDescendants = true
        MainFrame.Active = false
    else
        MainFrame.Active = true
    end
end

local function checkAnyAutoActive()
    -- Hàm kiểm tra xem có cần khóa tương tác menu không, logic chức năng sẽ điền vào
    return false
end

local function createTabChip(tabId, iconText, labelText, order)
    local btn = Instance.new("TextButton")
    btn.Name = "TabChip_" .. tabId
    btn.Parent = ScrollTabContainer
    btn.BackgroundColor3 = Theme.Card
    btn.Size = UDim2.new(0, 72, 1, 0)
    btn.Font = Enum.Font.GothamBold
    btn.Text = iconText .. " " .. labelText
    btn.TextColor3 = Theme.TextMuted
    btn.TextSize = 9
    btn.LayoutOrder = order
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 15) -- Dạng viên thuốc cực đẹp
    
    local stroke = Instance.new("UIStroke", btn)
    stroke.Thickness = 1
    stroke.Color = Theme.Border
    
    btn.MouseButton1Click:Connect(function()
        for id, tabBtn in pairs(tabButtons) do
            TweenService:Create(tabBtn.Btn, TweenInfo.new(0.2), {BackgroundColor3 = Theme.Card, TextColor3 = Theme.TextMuted}):Play()
            TweenService:Create(tabBtn.Stroke, TweenInfo.new(0.2), {Color = Theme.Border}):Play()
            if activePages[id] then activePages[id].Visible = false end
        end
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Theme.Accent, TextColor3 = Theme.TextPrimary}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Theme.Accent}):Play()
        if activePages[tabId] then activePages[tabId].Visible = true end
    end)
    
    tabButtons[tabId] = {Btn = btn, Stroke = stroke}
    return btn
end

-- Hàm tạo Cần gạt nhỏ nằm góc phải (Switch/Toggle) thu hẹp tối đa Hitbox chống click nhầm
