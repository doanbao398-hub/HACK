local function executeSkillSpamEngine()
    local activeKeys = {}
    for key, enabled in pairs(_G.SelectedSpamKeys) do
        if enabled then
            local enumKey = Enum.KeyCode[key]
            if enumKey then table.insert(activeKeys, enumKey) end
        end
    end
    if #activeKeys == 0 then return end
    for i = 1, #activeKeys do
        local targetKey = activeKeys[i]
        VirtualInputManager:SendKeyEvent(true, targetKey, false, game)
        task.wait(0.01)
        VirtualInputManager:SendKeyEvent(false, targetKey, false, game)
    end
end

