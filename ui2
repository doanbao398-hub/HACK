            accordion:TweenSize(UDim2.new(1, 0, 0, 34), Enum.EasingDirection.Out, Enum.EasingStyle.Quart, 0.25, true)
        end
    end)
    
    return contentContainer
end

-- Hàm tạo thanh kéo Slider mượt mà tối ưu khoảng cách di động
local function createModernSlider(parent, labelText, minVal, maxVal, startVal, callback)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(1, 0, 0, 40)
    container.BackgroundColor3 = Theme.Card
    container.Parent = parent
    Instance.new("UICorner", container).CornerRadius = UDim.new(0, 6)
    Instance.new("UIStroke", container).Color = Theme.Border
    
    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(0, 120, 0, 20)
    txt.Position = UDim2.new(0, 10, 0, 2)
    txt.BackgroundTransparency = 1
    txt.Font = Enum.Font.GothamSemibold
    txt.Text = labelText
    txt.TextColor3 = Theme.TextMuted
    txt.TextSize = 9.5
    txt.TextXAlignment = Enum.TextXAlignment.Left
    txt.Parent = container
    
    local valBox = Instance.new("TextBox")
    valBox.Size = UDim2.new(0, 45, 0, 16)
    valBox.Position = UDim2.new(1, -55, 0, 4)
    valBox.BackgroundColor3 = Theme.InnerCard
    valBox.Font = Enum.Font.GothamBold
    valBox.Text = tostring(startVal)
    valBox.TextColor3 = Theme.SwitchOn
    valBox.TextSize = 10
    valBox.Parent = container
    Instance.new("UICorner", valBox).CornerRadius = UDim.new(0, 4)
    
    local bar = Instance.new("TextButton")
    bar.Size = UDim2.new(1, -20, 0, 4)
    bar.Position = UDim2.new(0, 10, 0, 26)
    bar.BackgroundColor3 = Theme.InnerCard
    bar.Text = ""
    bar.Parent = container
    Instance.new("UICorner", bar).CornerRadius = UDim.new(1, 0)
    
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((startVal - minVal)/(maxVal - minVal), 0, 1, 0)
    fill.BackgroundColor3 = Theme.Accent
    fill.BorderSizePixel = 0
    fill.Parent = bar
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
    
    local function update(pos)
        local ratio = math.clamp((pos.X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
        local val = math.round(minVal + (ratio * (maxVal - minVal)))
        valBox.Text = tostring(val)
        fill.Size = UDim2.new(ratio, 0, 1, 0)
        callback(val)
    end
    
    local active = false
    bar.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then active = true update(i.Position) end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then active = false end end)
    UserInputService.InputChanged:Connect(function(i) if active and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then update(i.Position) end end)
    return container
end

