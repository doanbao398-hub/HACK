local function toggleRenameNPCs(enable)
    local folder = workspace:FindFirstChild("Ignore") and workspace.Ignore:FindFirstChild("NPCs")
    if not folder then return end
    for _, sub in ipairs(folder:GetChildren()) do
        if sub:IsA("Folder") and not blacklistedNpcFolders[string.lower(sub.Name)] then
            for _, npc in ipairs(sub:GetChildren()) do
                if npc:IsA("Model") then
                    if enable then
                        if not originalNpcNames[npc] then originalNpcNames[npc] = npc.Name end
                        npc.Name = NEW_NPC_NAME
                    else
                        if originalNpcNames[npc] then npc.Name = originalNpcNames[npc] end
                    end
                end
            end
        end
    end
    if not enable then table.clear(originalNpcNames) end
end

