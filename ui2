local function startMonsterFarmMechanics()
    if farmConnection then farmConnection:Disconnect(); farmConnection = nil end
    if not _G.autoMonsterFarm then local h = getHRP() if h then h.Anchored = false end return end

    task.spawn(function()
        while _G.autoMonsterFarm do
            if player.Character and player.Character:FindFirstChildOfClass("Humanoid") and player.Character.Humanoid.Health > 0 then
                if not currentTarget or not currentTarget.Parent or not currentTarget:FindFirstChild("HumanoidRootPart") or currentTarget.Humanoid.Health <= 0 then
                    currentTarget = getNextLoopTarget()
                end
                if currentTarget then
                    pcall(equipSelectedFarmItem)
                    if _G.FarmMode == "Spam Skills" then
                        executeSkillSpamEngine() task.wait(SPAM_KEY_DELAY)
                    else
                        local vs = camera.ViewportSize
                        VirtualInputManager:SendMouseButtonEvent(vs.X - 100, vs.Y - 100, 0, true, game, 0) task.wait(0.02)
                        VirtualInputManager:SendMouseButtonEvent(vs.X - 100, vs.Y - 100, 0, false, game, 0) task.wait(NORMAL_FARM_CLICK_DELAY)
                    end
                else task.wait(0.1) end
            else task.wait(0.1) end
        end
    end)

    farmConnection = RunService.Heartbeat:Connect(function()
        if not _G.autoMonsterFarm then return end
        local hrp = getHRP() if not hrp or player.Character.Humanoid.Health <= 0 then return end
        if currentTarget and currentTarget.Parent and currentTarget:FindFirstChild("HumanoidRootPart") then
            hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
            if _G.FarmMode == "Normal" then
                hrp.CFrame = CFrame.new((currentTarget.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)).Position, currentTarget.HumanoidRootPart.Position)
            else
                hrp.CFrame = CFrame.new(currentTarget.HumanoidRootPart.Position + Vector3.new(0, _G.MonsterDistance or 25, 0), currentTarget.HumanoidRootPart.Position)
            end
        end
    end)
end

local function startBossFarmMechanics()
