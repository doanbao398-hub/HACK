    contentList.Padding = UDim.new(0, 6)
    
    local isOpen = false
    contentList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        if isOpen then
            contentContainer.Size = UDim2.new(1, -12, 0, contentList.AbsoluteContentSize.Y)
            accordion.Size = UDim2.new(1, 0, 0, contentList.AbsoluteContentSize.Y + 46)
