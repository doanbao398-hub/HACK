local function mainFarmEngine()
    while _G.autoFarm do
        if checkHasJuice() then
            local snowPos = getSnowSafetyPosition()
            if snowPos then
                teleportTo(snowPos, true)
                while _G.autoFarm and checkHasJuice() do
                    local bp = player:FindFirstChild("Backpack") local char = player.Character
                    if bp and char and char:FindFirstChildOfClass("Humanoid") then
                        for i = 1, #juiceList do
                            local tool = bp:FindFirstChild(juiceList[i]) or char:FindFirstChild(juiceList[i])
                            if tool then
                                if tool.Parent == bp then char.Humanoid:EquipTool(tool) task.wait(0.1) end
                                tool:Activate() task.wait(0.2) tool:Deactivate() break
                            end
                        end
                    end
                    task.wait(0.1)
                end
                local hrp = getHRP() if hrp then hrp.Anchored = false end
            end
        else
            local targets = getSmartTargets()
            if #targets > 0 then
                for i = 1, #targets do
                    if not _G.autoFarm or checkHasJuice() then break end
                    local obj = targets[i]
                    local cd = obj and obj:FindFirstChildWhichIsA("ClickDetector", true)
                    local pos = getPosition(obj)
                    if cd and pos then
                        teleportTo(pos, false)
                        for c = 1, 4 do pcall(fireclickdetector, cd) task.wait(0.02) end
                        task.wait(CLICK_DELAY)
                    end
                end
            else task.wait(0.5) end
        end
        task.wait(0.5)
    end
end

local function startCompassLoop()
    while _G.autoCompass do
        local hrp = getHRP()
        if hrp then
            local targets = {}
            for _, obj in ipairs(workspace:GetChildren()) do
                if obj.Name == "Compass" and obj:FindFirstChild("CompassNeedle") then table.insert(targets, obj.CompassNeedle) end
            end
            if #targets > 0 then
                local oldCF, oldVel = hrp.CFrame, hrp.AssemblyLinearVelocity
                for _, needle in ipairs(targets) do
                    if not _G.autoCompass then break end
                    hrp.AssemblyLinearVelocity = Vector3.new(0,0,0)
                    hrp.CFrame = needle:IsA("BasePart") and needle.CFrame or needle:GetPivot()
                    task.wait(0.2)
                end
                if _G.autoCompass then hrp.CFrame = oldCF hrp.AssemblyLinearVelocity = oldVel end
            end
        end
        task.wait(COMPASS_INTERVAL)
    end
end

