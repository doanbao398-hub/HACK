    titleLabel.Position = UDim2.new(0, 10, 0, 0)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Font = Enum.Font.GothamSemibold
    titleLabel.Text = labelText
    titleLabel.TextColor3 = Theme.TextPrimary
    titleLabel.TextSize = 10.5
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = row
    
    -- Hitbox container của cần gạt được làm cực nhỏ gọn bên phải
    local SwitchHitbox = Instance.new("TextButton")
    SwitchHitbox.Name = "SwitchHitbox"
    SwitchHitbox.Size = UDim2.new(0, 36, 0, 20)
    SwitchHitbox.Position = UDim2.new(1, -46, 0.5, -10)
    SwitchHitbox.BackgroundColor3 = Theme.SwitchOff
    SwitchHitbox.Text = ""
    SwitchHitbox.Parent = row
    Instance.new("UICorner", SwitchHitbox).CornerRadius = UDim.new(1, 0)
    
    local Dot = Instance.new("Frame")
    Dot.Name = "Dot"
    Dot.Size = UDim2.new(0, 14, 0, 14)
    Dot.Position = UDim2.new(0, 3, 0.5, -7)
    Dot.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Dot.Parent = SwitchHitbox
    Instance.new("UICorner", Dot).CornerRadius = UDim.new(1, 0)
    
    local toggled = false
    SwitchHitbox.MouseButton1Click:Connect(function()
        toggled = not toggled
        if toggled then
            TweenService:Create(SwitchHitbox, TweenInfo.new(0.15), {BackgroundColor3 = Theme.SwitchOn}):Play()
            TweenService:Create(Dot, TweenInfo.new(0.15), {Position = UDim2.new(1, -17, 0.5, -7)}):Play()
        else
            TweenService:Create(SwitchHitbox, TweenInfo.new(0.15), {BackgroundColor3 = Theme.SwitchOff}):Play()
            TweenService:Create(Dot, TweenInfo.new(0.15), {Position = UDim2.new(0, 3, 0.5, -7)}):Play()
        end
        handleAFKMenuProtection(checkAnyAutoActive())
        signalCallback(toggled)
    end)
    
    return row
end

