-- Luồng 1: Vòng lặp Treo Sam hằng ngày (15 phút một lần)
task.spawn(function()
    while true do
        if _G.AutoTreoSam then
            print("[Auto Treo] Đến giờ đi lấy nhiệm vụ Sam hằng ngày...")
            pcall(chayLuongLaySam)
            task_wait(IntervalTreoSam) -- Chờ đúng 15 phút để chạy lại
        else
            task_wait(1)
        end
    end
end)

-- Luồng 2: Vòng lặp Auto Vứt Sam tự động
task.spawn(function()
    while true do
        if _G.AutoVutSam then
            local backpack = localPlayer:FindFirstChild("Backpack")
            local char = localPlayer.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            
            -- Tìm kiếm item mang tên Compass
            local compass = (backpack and backpack:FindFirstChild("Compass")) or (char and char:FindFirstChild("Compass"))
            
            if compass and hum then
                -- Nếu item đang nằm ở Balo thì ép nhân vật phải lôi ra cầm trên tay trước
                if compass.Parent == backpack then
                    pcall(function() hum:EquipTool(compass) end)
                    task_wait(0.2)
                end
                
                -- Giả lập nhấn phím Backspace vật lý để vứt vật phẩm đang cầm trên tay ra đất
                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Backspace, false, game)
                task_wait(0.05)
                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Backspace, false, game)
                
                print("[Auto Vứt] Đã thực hiện vứt 1 chiếc Compass ra đất!")
                task_wait(0.3) -- Nghỉ ngắn để tiếp tục lọc cái kế tiếp
            else
                task_wait(1) -- Không có Compass thì nghỉ 1 giây quét lại
            end
        else
            task_wait(1)
        end
    end
end)

