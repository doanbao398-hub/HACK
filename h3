-- Hàm đếm chính xác số lượng Compass đang có trong balo và trên tay
local function getCompassCount()
    local count = 0
    local backpack = localPlayer:FindFirstChild("Backpack")
    local char = localPlayer.Character
    
    if backpack then
        for _, item in ipairs(backpack:GetChildren()) do
            if item.Name == "Compass" then count = count + 1 end
        end
    end
    if char then
        for _, item in ipairs(char:GetChildren()) do
            if item.Name == "Compass" then count = count + 1 end
        end
    end
    return count
end

-- =========================================================================
-- 🦾 LUỒNG XỬ LÝ CHÍNH: CLICK SAM CHUẨN ĐỘNG CỦA BẠN
-- =========================================================================
local function chayLuongLaySam()
    local character = localPlayer.Character
    local myRoot = character and character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end

    local sam = workspace:FindFirstChild("Ignore") 
        and workspace.Ignore:FindFirstChild("NPCs") 
        and workspace.Ignore.NPCs:FindFirstChild("DailyQuest") 
        and workspace.Ignore.NPCs.DailyQuest:FindFirstChild("Sam")

    -- Lưu vị trí farm cũ ban đầu
    local originalPlayerCFrame = myRoot.CFrame
    local initialCompassCount = getCompassCount()

    if sam and sam:FindFirstChild("HumanoidRootPart") then
        local samRoot = sam.HumanoidRootPart
        local clickDetector = samRoot:FindFirstChild("ClickDetector")
        
        if clickDetector then
            clickDetector.MaxActivationDistance = math.huge
            
            -- Dịch chuyển tới trước mặt Sam
            myRoot.CFrame = samRoot.CFrame * CFrame.new(0, 0, -3)
            task_wait(0.15)
            
            -- Kích hoạt click mở giao diện đối thoại
            if fireclickdetector then
                fireclickdetector(clickDetector)
            else
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
                task_wait(0.01)
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
            end
            print("[Hệ thống] Đã tiếp cận và mở bảng NPC Sam!")
        else
            warn("Không tìm thấy ClickDetector!")
            return
        end
    else
        warn("Không tìm thấy NPC Sam!")
        return
    end

    -- Đợi và quét giao diện động xuất hiện
    local questGui = playerGui:WaitForChild("QuestGui", 5)
    if questGui then
        local dialogue = questGui:FindFirstChild("Dialogue", 5)
        local options = dialogue and dialogue:FindFirstChild("Options", 5)
        
        if options then
            local optionButton = options:WaitForChild("Option", 5)
            if optionButton then
                task_wait(0.3) -- Chờ UI định hình tọa độ ổn định
                
                local x = optionButton.AbsolutePosition.X + (optionButton.AbsoluteSize.X / 2)
                local y = optionButton.AbsolutePosition.Y + (optionButton.AbsoluteSize.Y / 2) + 58
                
                -- LẦN CLICK THỨ 1
                VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 1)
                task_wait(0.05)
                VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 1)
                
                task_wait(0.2) -- Giãn cách nhận lệnh
                
                -- LẦN CLICK THỨ 2
                VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 1)
                task_wait(0.05)
                VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 1)
                print("[Hệ thống] Đã nhấn đúp nhận nhiệm vụ.")
                
                -- Kiểm tra thành quả cấp vật phẩm Compass
                task_wait(1.0)
                local currentCompassCount = getCompassCount()
                
                if currentCompassCount > initialCompassCount or currentCompassCount > 0 then
                    local leaveButton = options:FindFirstChild("Leave")
                    if leaveButton then
                        task_wait(0.05)
                        local lx = leaveButton.AbsolutePosition.X + (leaveButton.AbsoluteSize.X / 2)
                        local ly = leaveButton.AbsolutePosition.Y + (leaveButton.AbsoluteSize.Y / 2) + 58
                        
                        VirtualInputManager:SendMouseButtonEvent(lx, ly, 0, true, game, 1)
                        task_wait(0.05)
                        VirtualInputManager:SendMouseButtonEvent(lx, ly, 0, false, game, 1)
                    end
                    
                    -- Dịch chuyển quay trở về bãi farm cũ
                    task_wait(0.1)
                    myRoot.CFrame = originalPlayerCFrame
                    print("[Hệ thống] Nhận xong! Đã đưa bạn quay lại vị trí farm.")
                end
            end
        end
    end
end

