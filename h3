local function mainFarmEngine()
    cleanupMemory() 
    updateBarrelCache()
    
    local backpack = player:WaitForChild("Backpack", 5)
    if backpack then
        farmConnections.juiceAdded = backpack.ChildAdded:Connect(function(child)
            if table.find(juiceList, child.Name) then
                task.delay(0.05, function()
                    checkAndDrinkJuice()
                end)
            end
        end)
    end

    task_spawn(startMixerLoop)
    local lastCleanup = tick()

    while _G.autoFarm do
        if tick() - lastCleanup >= 5.0 then
            task_wait(0.01) 
            updateBarrelCache()
            lastCleanup = tick()
        end

        if #barrelCache > 0 then
            for i = #barrelCache, 1, -1 do
                if not _G.autoFarm then break end
                
                local data = barrelCache[i]
                local obj = data.instance
                local cd = data.detector
                
                if obj and obj.Parent and cd and cd.Parent then
                    local hrp = getHRP()
                    local pos = obj:IsA("BasePart") and obj.Position or (obj.PrimaryPart and obj.PrimaryPart.Position)
                    
                    if hrp and pos then
                        hrp.AssemblyLinearVelocity = Vector3_new(0, 0, 0)
                        hrp.CFrame = CFrame_new(pos + Vector3_new(0, 3.4, 0))
                        
                        safeRemoteClick(cd)
                        task_wait(0.01)
                        if obj.Parent then safeRemoteClick(cd) end
                        
                        task_wait(0.07) 
                    end
                else
                    table.remove(barrelCache, i)
                end
            end
        else
            task_wait(0.3) 
            updateBarrelCache()
        end
        task_wait(0.005)
    end
    cleanupMemory() 
end

local function startCompassLoop()
